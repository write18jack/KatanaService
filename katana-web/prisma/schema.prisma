model Katana {
  id String @id @default(cuid())

  // 基本情報
  shopName String // 店舗名
  name     String // 銘
  katanaType     String // 種別 (打刀, 脇差, 短刀など)
  era      String? // 時代
  price    Int // 価格
  status   String // 在庫状況 (例: 販売中, 売約済)

  // リレーション
  dealerId String
  dealer   User   @relation(fields: [dealerId], references: [id])

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  katanaRequests KatanaRequest[]
}

// 申請データ（追加・編集・削除のすべてをここで管理）
model KatanaRequest {
  id     String @id @default(uuid())
  status String @default("PENDING")
  crudType   String // "CREATE", "UPDATE", "DELETE"

  // 申請内容（カラムとして定義）
  shopName   String
  name       String
  katanaType String
  era        String
  price      Int

  // リレーション定義
  applicantId    String
  applicant      User    @relation(fields: [applicantId], references: [id])
  targetKatanaId String?
  targetKatana   Katana? @relation(fields: [targetKatanaId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
