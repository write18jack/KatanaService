generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String          @id @default(uuid())
  name           String          @unique
  email          String?         @unique
  emailVerified  DateTime?
  image          String?
  password       String
  role           String          @default("user")
  katanaRequests KatanaRequest[] // 逆リレーションを追加

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  katanas Katana[]
}

// -----------------------------
// NEW: enum（normalizeと一致させる）
// -----------------------------
enum KatanaType {
  KATANA
  WAKIZASHI
  TANTO
  UNKNOWN
}

enum Era {
  HEIAN
  KAMAKURA
  MUROMACHI
  MOMOYAMA
  EDO
  MODERN
  UNKNOWN
}

// -----------------------------
// NEW: 市場データ（主役）
// -----------------------------
model KatanaListing {
  id          String   @id @default(cuid())

  name        String
  price       Int?

  katanaType  KatanaType
  era         Era?

  source      String
  // 同じ商品を二重登録しないためのURL（ユニーク制約を付与）
  sourceUrl   String   @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // relations
  rawData      RawListing?
  priceHistory PriceHistory[]

  @@index([katanaType, era])
  @@index([source])
}

// -----------------------------
// NEW: 生データ（超重要）
// -----------------------------
model RawListing {
  id          String   @id @default(cuid())

  sourceUrl   String   @unique
  rawJson     Json

  createdAt   DateTime @default(now())

  listingId   String   @unique
  listing     KatanaListing @relation(fields: [listingId], references: [id])
}

// -----------------------------
// NEW: 価格履歴（相場の核）
// -----------------------------
model PriceHistory {
  id         String   @id @default(cuid())

  listingId  String
  listing    KatanaListing @relation(fields: [listingId], references: [id])

  price      Int
  recordedAt DateTime @default(now())

  @@index([listingId])
  @@index([recordedAt])
}

// 格付けの定義
// enum Grade {
//   JuyoBijutsu // 重要美術品
//   TokubetsuJuyoToken // 特別重要刀剣
//   JuyoToken // 重要刀剣
//   TokubetsuHozonToken // 特別保存刀剣
//   HozonToken // 保存刀剣
// }

model Katana {
  id String @id @default(cuid())

  // 基本情報
  shopName   String // 店舗名
  name       String // 銘
  katanaType String // 種別 (打刀, 脇差, 短刀など)
  era        String? // 時代
  price      Int // 価格
  status     String // 在庫状況 (例: 販売中, 売約済)
  imageUrl   String?

  // リレーション定義
  dealerId String
  dealer   User   @relation(fields: [dealerId], references: [id])
  version  Int    @default(0) // 排他制御用

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  katanaRequests KatanaRequest[]
}

// 申請データ（追加・編集・削除のすべてをここで管理）
model KatanaRequest {
  id       String @id @default(uuid())
  status   String @default("PENDING") // PENDING, APPROVED, REJECTED
  crudType String // "CREATE", "UPDATE", "DELETE"

  // 申請内容（カラムとして定義）
  shopName   String
  name       String
  katanaType String
  era        String
  price      Int
  imageUrl   String?

  // リレーション定義
  applicantId    String
  applicant      User    @relation(fields: [applicantId], references: [id])
  targetKatanaId String?
  targetKatana   Katana? @relation(fields: [targetKatanaId], references: [id])

  // 更新時の整合性チェック用（オプション）
  // targetVersion Int?  // 更新申請時のKatana.versionを記録しておくとより厳密です

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
