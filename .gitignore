build/
.gradle/
*/build/
.kotlin/
.idea/
*.iml
local.properties
.externalNativeBuild
.cxx
*.jks
*.gpg

# --- Debug & Logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- OS & Env ---
.DS_Store
.env*
*.pem
.vercel
